# PRISM API local environment
# Copy this file to .env in the same folder and fill in local values.

# Required for Gemini-powered consent summaries, compliance scans, and ID extraction.
GOOGLE_API_KEY=your_gemini_api_key

# Local PostgreSQL settings. docker-compose.yml provides matching defaults.
DB_USER=postgres
DB_PASSWORD=prism_secret
DB_HOST=localhost
DB_PORT=5432
DB_NAME=prism_db

# Optional override. Prefer individual DB_* variables for local Docker usage.
# DATABASE_URL=postgresql://postgres:prism_secret@localhost:5432/prism_db

# Future Google Cloud server-side integrations.
# Do not commit the service account JSON file.
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/google-service-account.json

# Future payment or partner-credit integrations. Not required for the MVP.
# RAZORPAY_KEY_ID=your_razorpay_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret
